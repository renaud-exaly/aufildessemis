# Copy this file to `.env` (and `.env.local` for dev overrides).
# Never commit real secrets.

# ---------- Core ----------
# `openssl rand -base64 32` to generate a strong secret.
PAYLOAD_SECRET=replace_me_with_a_long_random_string
PAYLOAD_PUBLIC_SERVER_URL=https://aufildessemis.be

# ---------- Database ----------
# In docker-compose, `app` reaches `postgres` via the service hostname.
# For local dev outside Docker, point to a local Postgres instead.
POSTGRES_USER=semis
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=au_fil_des_semis
DATABASE_URI=postgres://semis:replace_me@postgres:5432/au_fil_des_semis

# ---------- Network ----------
# Loopback host port for the app (proxied by external Caddy/Nginx).
APP_PORT=3011

# ---------- Reverse proxy / TLS (only used with the `standalone` Caddy profile) ----------
DOMAIN=aufildessemis.be
CADDY_EMAIL=admin@aufildessemis.be

# ---------- Email (Resend) ----------
# Free tier: 3000 emails/month. Sender domain must have SPF/DKIM/DMARC configured.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@aufildessemis.be
RESEND_TO_EMAIL=contact@aufildessemis.be
RESEND_AUDIENCE_ID=

# ---------- Cron ----------
# Bearer token expected by /api/cron/reminders. Set to a long random string and
# inject it into the cron container that calls the endpoint daily.
CRON_SECRET=replace_me_with_a_long_random_string
