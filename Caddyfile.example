# Reverse proxy + TLS automatique pour Au fil des semis.
# DOMAIN et CADDY_EMAIL sont injectés via docker-compose env.
# Let's Encrypt délivre / renouvelle les certificats automatiquement.

{
	email {$CADDY_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	# Forward tout vers l'app Next.js.
	reverse_proxy app:3000

	# Cache long pour les assets statiques hashés de Next.
	@nextStatic path /_next/static/*
	header @nextStatic Cache-Control "public, max-age=31536000, immutable"

	# Headers de sécurité (minimaux ; à durcir si besoin).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
	}
}
